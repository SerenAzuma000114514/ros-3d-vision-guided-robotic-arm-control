<?xml version="1.0"?>
<launch>
  <!-- 
  精简版MoveIt规划执行启动文件
  注意：这个文件被marm_bringup_moveit.launch调用
  假设Gazebo和控制器已经在其他地方启动
  -->

  <!-- ========== 参数配置 ========== -->
  <!-- 规划器类型 -->
  <arg name="pipeline" default="ompl" />
  
  <!-- 调试模式 -->
  <arg name="debug" default="false" />
  
  <!-- 是否加载机器人描述 -->
  <arg name="load_robot_description" default="false" />  <!-- 设置为false，因为Gazebo已经加载了 -->
  
  <!-- 是否启动RViz -->
  <arg name="use_rviz" default="true" />
  
  <!-- 控制器管理器类型 -->
  <arg name="moveit_controller_manager" default="ros_control" />  <!-- 必须与您的控制器配置匹配 -->
  
  <!-- 是否允许轨迹执行 -->
  <arg name="allow_trajectory_execution" default="true" />

  <!-- ========== 启动move_group节点 ========== -->
  <!-- MoveIt的核心规划与执行节点 -->
  <include file="$(find marm_moveit_config)/launch/move_group.launch">
    <arg name="allow_trajectory_execution" value="$(arg allow_trajectory_execution)" />
    <arg name="moveit_controller_manager" value="$(arg moveit_controller_manager)" />
    <arg name="fake_execution_type" value="interpolate" />
    <arg name="info" value="$(arg debug)" />
    <arg name="debug" value="$(arg debug)" />
    <arg name="pipeline" value="$(arg pipeline)" />
    <arg name="load_robot_description" value="$(arg load_robot_description)" />
  </include>

  <!-- ========== 启动RViz可视化 ========== -->
  <!-- 除非明确指定不启动，否则默认启动RViz -->
  <include file="$(find marm_moveit_config)/launch/moveit_rviz.launch" if="$(arg use_rviz)">
    <arg name="rviz_config" value="$(find marm_moveit_config)/launch/moveit.rviz"/>
    <arg name="debug" value="$(arg debug)" />
  </include>

</launch>
