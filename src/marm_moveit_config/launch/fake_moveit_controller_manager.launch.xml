<?xml version="1.0"?>
<launch>
  <!-- 这里使用真实的插件类名 -->
  <arg name="moveit_controller_manager" default="moveit_fake_controller_manager/MoveItFakeControllerManager"/>
  <param name="moveit_controller_manager" value="$(arg moveit_controller_manager)"/>
  
  <!-- 关键：指定连接到真实的Gazebo控制器管理器 -->
  <param name="controller_manager_name" value="/marm_robot/controller_manager"/>
  <param name="use_controller_manager" value="true"/>
  
  <!-- 加载控制器配置 -->
  <rosparam file="$(find marm_moveit_config)/config/controllers.yaml"/>
</launch>


