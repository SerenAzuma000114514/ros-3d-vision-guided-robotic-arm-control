    <!-- ros_control plugin -->
    <gazebo>
        <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
            <robotNamespace>/marm_robot</robotNamespace>
        </plugin>
    </gazebo>
    <gazebo>
        <plugin filename="libgazebo_ros_link_attacher.so" name="ros_link_attacher_plugin" />
    </gazebo>
    <!-- 相机安装link -->
    <link name="camera_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
            <material name="black">
                <color rgba="0 0 0 1" />
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>
    </link>
    <!-- 相机固定到base_link，xyz/rpy根据你的实际安装位置调整 -->
    <!-- 改这里：parent改为world，xyz让相机悬在机械臂上方侧面 -->
    <joint name="camera_joint" type="fixed">
        <parent link="world" />
        <child link="camera_link" />
        <origin rpy="0 1.5708 0" xyz="0.5 -0.5 1.2" />
    </joint>
    <!-- 光心坐标系（Gazebo插件需要） -->
    <link name="camera_link_optical" />
    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link" />
        <child link="camera_link_optical" />
        <origin rpy="-1.5707 0 -1.5707" xyz="0 0 0" />
    </joint>
    <!-- Gazebo深度相机插件 -->
    <gazebo reference="camera_link">
        <sensor name="camera" type="depth">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>5.0</far>
                </clip>
            </camera>
            <plugin filename="libgazebo_ros_openni_kinect.so" name="camera_plugin">
                <baseline>0.1</baseline>
                <alwaysOn>true</alwaysOn>
                <updateRate>10</updateRate>
                <cameraName>camera</cameraName>
                <frameName>camera_link_optical</frameName>
                <imageTopicName>rgb/image_raw</imageTopicName>
                <depthImageTopicName>depth/image_raw</depthImageTopicName>
                <pointCloudTopicName>depth/points</pointCloudTopicName>
                <cameraInfoTopicName>rgb/camera_info</cameraInfoTopicName>
                <pointCloudCutoff>0.1</pointCloudCutoff>
                <pointCloudCutoffMax>5.0</pointCloudCutoffMax>
            </plugin>
        </sensor>
    </gazebo>
    <!-- 夹爪基座，固定在Link6上 -->
    <link name="gripper_base">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1" />
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.05 0.05" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>
    </link>
    <joint name="gripper_base_joint" type="fixed">
        <parent link="Link6" />
        <child link="gripper_base" />
        <!-- 夹爪安装在Link6末端正下方 -->
        <origin rpy="0 0 0" xyz="0 0 -0.02" />
    </joint>
    <!-- 左指 -->
    <link name="gripper_left">
        <visual>
            <geometry>
                <box size="0.01 0.02 0.06" />
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1" />
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.01 0.02 0.06" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>
    </link>
    <joint name="gripper_left_joint" type="prismatic">
        <parent link="gripper_base" />
        <child link="gripper_left" />
        <origin rpy="0 0 0" xyz="0.02 0 0.05" />
        <!-- 沿x方向滑动 -->
        <axis xyz="1 0 0" />
        <!-- 开合范围：0是闭合，0.04是完全打开 -->
        <limit effort="100" lower="0" upper="0.04" velocity="0.02" />
    </joint>
    <!-- 右指 -->
    <link name="gripper_right">
        <visual>
            <geometry>
                <box size="0.01 0.02 0.06" />
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1" />
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.01 0.02 0.06" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05" />
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </inertial>
    </link>
    <joint name="gripper_right_joint" type="prismatic">
        <parent link="gripper_base" />
        <child link="gripper_right" />
        <origin rpy="0 0 0" xyz="-0.02 0 0.05" />
        <!-- 沿x方向反向滑动 -->
        <axis xyz="-1 0 0" />
        <limit effort="100" lower="0" upper="0.04" velocity="0.02" />
    </joint>
    <!-- ========== 方案一：增加手指的摩擦系数 ========== -->
    <gazebo reference="gripper_left">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
    </gazebo>
    <gazebo reference="gripper_right">
        <mu1>100.0</mu1>
        <mu2>100.0</mu2>
    </gazebo>
    <transmission name="trans_gripper_left_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="gripper_left_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="gripper_left_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="trans_gripper_right_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="gripper_right_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="gripper_right_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
</robot>

