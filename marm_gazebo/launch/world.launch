<launch>

  <!-- these are the arguments you can pass this launch file, for example paused:=true -->
  <arg name="paused" default="false"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>

<include file="$(find gazebo_ros)/launch/empty_world.launch">
  <arg name="world_name" value="$(find marm_gazebo)/worlds/table_world.world"/>
  <arg name="debug" value="$(arg debug)" />
  <arg name="gui" value="$(arg gui)" />
  <arg name="paused" value="$(arg paused)"/>
  <arg name="use_sim_time" value="$(arg use_sim_time)"/>
  <arg name="headless" value="$(arg headless)"/>
</include>

  <!-- Load the URDF into the ROS Parameter Server -->

  <param name="robot_description" command="$(find xacro)/xacro '$(find marm_gazebo)/urdf/marm_robot.xacro'" />

  <!-- <param name="robot_description" textfile="$(find YOUR_ROBOT_DESCRIPTION_PACKAGE)/urdf/YOUR_ROBOT_MODEL.urdf" /> -->

  <!-- Run a python script to the send a service call to gazebo_ros to spawn a URDF robot -->

  <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen"
	args="-urdf -model marm_robot -param robot_description"/>
	
<!-- 桌子模型参数 -->
<param name="table_description" textfile="$(find marm_gazebo)/urdf/table.urdf" />
<!-- 小物块模型参数 -->
<param name="box_description" textfile="$(find marm_gazebo)/urdf/simple_cube.urdf" />

<param name="cylinder_description" textfile="$(find marm_gazebo)/urdf/simple_cylinder.urdf" />

<!-- 生成矮平台：底面贴地，中心高度 0.05m -->
<node name="spawn_table_node" pkg="gazebo_ros" type="spawn_model" output="screen"
      args="-urdf -param table_description -model table -x 0.45 -y 0.1 -z 0.05" />

<!-- 生成小物块，放在平台顶面上 -->
<node name="spawn_box_node" pkg="gazebo_ros" type="spawn_model" output="screen"
      args="-urdf -param box_description -model unique_cube -x 0.45 -y 0.1 -z 0.165" />
      
<node name="spawn_cylinder_node" pkg="gazebo_ros" type="spawn_model" output="screen"
      args="-urdf -param cylinder_description -model unique_cylinder -x 0.55 -y 0.15 -z 0.165" />
     
     

</launch>
