<?xml version="1.0"?>
<robot name="simple_cube_with_protrusion">
  <link name="cube_link">
    <inertial>
      <mass value="0.01" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>

    <!-- 主体（立方体） -->
    <visual>
      <geometry><box size="0.02 0.1 0.03" /></geometry>
      <material name="red"><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.02 0.1 0.03" /></geometry>
    </collision>

    <!-- 顶部凸起（位于主体上表面中心） -->
    <!-- 凸起尺寸：长0.03，宽0.03，高0.02 -->
    <visual name="protrusion_visual">
      <origin xyz="0 0 0.04" />  
      <geometry><box size="0.07 0.1 0.02" /></geometry>
      <material name="red"><color rgba="0.8 0.2 0.2 1"/></material>
    </visual>
    <collision name="protrusion_collision">
      <origin xyz="0 0 0.04" />
      <geometry><box size="0.07 0.1 0.02" /></geometry>
    </collision>
  </link>

  <gazebo reference="cube_link">
    <material>Gazebo/Red</material>
    <kp>10000000.0</kp>
    <kd>1.0</kd>
    <mu1>100</mu1>
    <mu2>100</mu2>
    <minDepth>0.003</minDepth>
    <maxVel>0.0</maxVel>       
  </gazebo>
</robot>
